{% extends 'base.html.twig' %}

{% block title %}SecureScan — {{ vuln.package }} · {{ vuln.cve }}{% endblock %}

{% block stylesheets %}
<style>
.detail-wrap { padding: 32px 40px; max-width: 1400px; margin: 0 auto; }
.breadcrumb {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--font-mono); font-size: 0.65rem; color: var(--text3); margin-bottom: 28px;
}
.bc-link { color: var(--cyan); text-decoration: none; }
.bc-link:hover { text-decoration: underline; }
.bc-sep { color: var(--border2); }
.detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 16px; }
.detail-left { display: flex; flex-direction: column; gap: 14px; }
.d-card { background: var(--card); border: 1px solid var(--border2); border-radius: var(--radius-xl); padding: 26px; }
.d-card-label {
  font-family: var(--font-mono); font-size: 0.6rem; color: var(--text3);
  letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;
  display: flex; align-items: center; gap: 8px;
}
.d-card-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.detail-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 18px; }
.detail-pkg-name { font-size: 1.25rem; font-weight: 800; letter-spacing: -0.3px; line-height: 1.2; }
.detail-ver { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text3); font-weight: 400; margin-top: 4px; }
.cve-badge {
  font-family: var(--font-mono); font-size: 0.68rem; padding: 6px 12px;
  border: 1px solid rgba(0,217,245,0.3); background: var(--cyan-dim);
  color: var(--cyan); border-radius: var(--radius); white-space: nowrap; flex-shrink: 0;
}
.detail-desc { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text2); line-height: 1.8; padding-top: 18px; border-top: 1px solid var(--border); }

/* Fix command */
.fix-block {
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: var(--radius); padding: 14px 16px;
  font-family: var(--font-mono); font-size: 0.75rem; color: var(--green);
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  margin-top: 18px;
}
.fix-label { font-size: 0.6rem; color: var(--text3); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
.fix-copy {
  background: transparent; border: 1px solid var(--border2); color: var(--text2);
  padding: 5px 10px; border-radius: var(--radius-sm); cursor: pointer;
  font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.5px;
  transition: all 0.15s; white-space: nowrap;
}
.fix-copy:hover { border-color: var(--green); color: var(--green); }

/* Sidebar */
.detail-right { display: flex; flex-direction: column; gap: 14px; }
.owasp-sidebar-badge {
  display: flex; align-items: center; gap: 10px;
  background: var(--red-dim); border: 1px solid rgba(245,54,92,0.25);
  border-radius: var(--radius); padding: 10px 14px; margin-bottom: 12px;
}
.osb-code { font-family: var(--font-mono); font-size: 0.68rem; font-weight: 700; color: var(--red); }
.osb-name { font-size: 0.82rem; font-weight: 600; }
.osb-desc { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text3); line-height: 1.6; }
.sev-row { display: flex; flex-direction: column; gap: 8px; }
.sev-row-top { display: flex; align-items: center; justify-content: space-between; }
.sev-row-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; }
.sev-row-score { font-family: var(--font-mono); font-size: 0.7rem; color: var(--red); font-weight: 700; }
.sev-bar { height: 4px; background: var(--border2); border-radius: 2px; overflow: hidden; margin-bottom: 10px; }
.sev-bar-fill { height: 100%; border-radius: 2px; background: var(--red); width: 85%; }
.action-stack { display: flex; flex-direction: column; gap: 8px; }
.act-btn {
  width: 100%; padding: 12px; font-family: var(--font-sans); font-weight: 700;
  font-size: 0.8rem; border-radius: var(--radius); cursor: pointer;
  transition: all 0.15s; letter-spacing: 0.2px;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.act-primary { background: var(--cyan); color: var(--bg); border: none; }
.act-primary:hover { background: #33E4FF; }
.act-secondary { background: transparent; color: var(--text2); border: 1px solid var(--border2); }
.act-secondary:hover { border-color: var(--cyan); color: var(--cyan); }

@media (max-width: 1024px) { .detail-grid { grid-template-columns: 1fr; } }
@media (max-width: 768px) { .detail-wrap { padding: 24px 20px; } }
</style>
{% endblock %}

{% block body %}
<div class="detail-wrap">

  <div class="breadcrumb">
    <a class="bc-link" href="{{ path('app_dashboard') }}">Dashboard</a>
    <span class="bc-sep">›</span>
    <span>{{ vuln.package }}</span>
    <span class="bc-sep">›</span>
    <span style="color:var(--cyan)">{{ vuln.cve }}</span>
  </div>

  <div class="detail-grid">
    <div class="detail-left">
      <div class="d-card">
        <div class="d-card-label">Vulnérabilité</div>
        <div class="detail-head">
          <div>
            <div class="detail-pkg-name">{{ vuln.package }}</div>
            <div class="detail-ver">Version affectée : {{ vuln.version }}</div>
          </div>
          {% if vuln.cve %}
            <div class="cve-badge">{{ vuln.cve }}</div>
          {% endif %}
        </div>
        <div class="detail-desc">{{ vuln.title }}</div>
        {% if vuln.fix %}
          <div style="margin-top: 18px;">
            <div class="fix-label">Commande de correction</div>
            <div class="fix-block">
              <code>{{ vuln.fix }}</code>
              <button class="fix-copy" onclick="navigator.clipboard.writeText('{{ vuln.fix }}')">Copier</button>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="detail-right">
      <div class="d-card">
        <div class="d-card-label">Catégorie OWASP</div>
        <div class="owasp-sidebar-badge">
          <span class="osb-code">A05:2025</span>
          <span class="osb-name">Injection</span>
        </div>
        <div class="osb-desc">
          Les failles d'injection surviennent quand des données non fiables
          sont envoyées à un interpréteur en tant que commande ou requête.
        </div>
      </div>

      <div class="d-card">
        <div class="d-card-label">Sévérité</div>
        <div class="sev-row">
          <div class="sev-row-top">
            <span class="sev-row-label">CVSS Score</span>
            <span class="sev-row-score">8.5 / 10</span>
          </div>
          <div class="sev-bar"><div class="sev-bar-fill"></div></div>
          <span class="sev-badge sev-c" style="width:fit-content">{{ vuln.severity|capitalize }}</span>
        </div>
      </div>

      <div class="d-card">
        <div class="d-card-label">Actions</div>
        <div class="action-stack">
          {% if vuln.url %}
            <a href="{{ vuln.url }}" target="_blank" class="act-btn act-primary" style="text-decoration:none">
              ↗ Voir l'advisory
            </a>
          {% endif %}
          <a href="{{ path('app_dashboard') }}" class="act-btn act-secondary" style="text-decoration:none">
            ← Retour au dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
