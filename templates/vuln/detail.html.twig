{% extends 'base.html.twig' %}
{% block title %}SecureScan — {{ vuln.package }} · {{ vuln.cve }}{% endblock %}

{% block stylesheets %}
<style>
.detail-wrap { padding: 32px 40px; max-width: 1200px; margin: 0 auto; }
.breadcrumb {
  display: flex; align-items: center; gap: 8px;
  font-size: 0.8rem; color: var(--text3); margin-bottom: 28px;
}
.bc-link { color: var(--primary); text-decoration: none; font-weight: 500; }
.bc-link:hover { text-decoration: underline; }
.bc-sep { color: var(--border2); }

.detail-grid { display: grid; grid-template-columns: 1fr 300px; gap: 16px; }
.detail-left  { display: flex; flex-direction: column; gap: 14px; }

.d-card {
  background: var(--card); border: 1.5px solid var(--border);
  border-radius: var(--radius-xl); padding: 26px;
  box-shadow: var(--shadow);
}
.d-card-label {
  font-size: 0.72rem; font-weight: 700; color: var(--text3);
  letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}
.d-card-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.detail-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 18px; }
.detail-pkg-name { font-size: 1.3rem; font-weight: 900; letter-spacing: -0.3px; color: var(--text); }
.detail-ver { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text3); margin-top: 4px; }
.cve-badge {
  font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600;
  padding: 6px 14px; border-radius: 100px;
  border: 1.5px solid rgba(255,107,107,0.25); background: rgba(255,107,107,0.08);
  color: var(--primary); white-space: nowrap; flex-shrink: 0;
}
.detail-desc {
  font-size: 0.88rem; color: var(--text2); line-height: 1.8;
  padding-top: 18px; border-top: 1px solid var(--border);
}

.fix-block {
  background: rgba(5,150,105,0.05); border: 1.5px solid rgba(5,150,105,0.2);
  border-radius: var(--radius); padding: 14px 16px;
  font-family: var(--font-mono); font-size: 0.78rem; color: var(--green);
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  margin-top: 18px;
}
.fix-label { font-size: 0.65rem; color: var(--text3); font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 6px; }
.fix-copy {
  background: transparent; border: 1.5px solid rgba(5,150,105,0.25); color: var(--green);
  padding: 5px 12px; border-radius: 100px; cursor: pointer;
  font-family: var(--font-sans); font-size: 0.72rem; font-weight: 600;
  transition: all 0.15s; white-space: nowrap;
}
.fix-copy:hover { background: rgba(5,150,105,0.08); }

/* Sidebar */
.detail-right { display: flex; flex-direction: column; gap: 14px; }
.owasp-sidebar-badge {
  display: flex; align-items: center; gap: 10px;
  background: rgba(220,38,38,0.05); border: 1.5px solid rgba(220,38,38,0.15);
  border-radius: var(--radius); padding: 12px 14px; margin-bottom: 12px;
}
.osb-code { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700; color: var(--red); }
.osb-name { font-size: 0.88rem; font-weight: 700; color: var(--text); }
.osb-desc { font-size: 0.8rem; color: var(--text2); line-height: 1.6; }

.sev-row { display: flex; flex-direction: column; gap: 8px; }
.sev-row-top { display: flex; align-items: center; justify-content: space-between; }
.sev-row-label { font-size: 0.72rem; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
.sev-row-score { font-family: var(--font-mono); font-size: 0.78rem; color: var(--red); font-weight: 700; }
.sev-bar { height: 6px; background: var(--surface); border: 1px solid var(--border); border-radius: 3px; overflow: hidden; margin-bottom: 10px; }
.sev-bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #FF6B6B, #A78BFA); width: 85%; }

.action-stack { display: flex; flex-direction: column; gap: 8px; }
.act-btn {
  width: 100%; padding: 12px; font-family: var(--font-sans); font-weight: 700;
  font-size: 0.82rem; border-radius: 100px; cursor: pointer;
  transition: all 0.15s;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  text-decoration: none;
}
.act-primary { background: var(--gradient); color: #fff; border: none; }
.act-primary:hover { opacity: 0.88; }
.act-secondary {
  background: transparent; color: var(--text2);
  border: 1.5px solid var(--border2);
}
.act-secondary:hover { border-color: var(--primary); color: var(--primary); }

@media (max-width: 1024px) { .detail-grid { grid-template-columns: 1fr; } }
@media (max-width: 768px)  { .detail-wrap { padding: 24px 20px; } }
</style>
{% endblock %}

{% block body %}
<div class="detail-wrap">

  <div class="breadcrumb">
    <a class="bc-link" href="{{ path('app_dashboard') }}">Dashboard</a>
    <span class="bc-sep">›</span>
    <span>{{ vuln.package }}</span>
    <span class="bc-sep">›</span>
    <span style="color:var(--primary)">{{ vuln.cve }}</span>
  </div>

  <div class="detail-grid">
    <div class="detail-left">
      <div class="d-card">
        <div class="d-card-label">Vulnérabilité</div>
        <div class="detail-head">
          <div>
            <div class="detail-pkg-name">{{ vuln.package }}</div>
            <div class="detail-ver">Version affectée : {{ vuln.version }}</div>
          </div>
          {% if vuln.cve %}
            <div class="cve-badge">{{ vuln.cve }}</div>
          {% endif %}
        </div>
        <div class="detail-desc">{{ vuln.title }}</div>
        {% if vuln.fix %}
          <div style="margin-top:18px;">
            <div class="fix-label">Commande de correction</div>
            <div class="fix-block">
              <code>{{ vuln.fix }}</code>
              <button class="fix-copy" onclick="navigator.clipboard.writeText('{{ vuln.fix }}')">Copier</button>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="detail-right">
      <div class="d-card">
        <div class="d-card-label">Catégorie OWASP</div>
        <div class="owasp-sidebar-badge">
          <span class="osb-code">A05:2025</span>
          <span class="osb-name">Injection</span>
        </div>
        <div class="osb-desc">
          Les failles d'injection surviennent quand des données non fiables
          sont envoyées à un interpréteur en tant que commande ou requête.
        </div>
      </div>

      <div class="d-card">
        <div class="d-card-label">Sévérité</div>
        <div class="sev-row">
          <div class="sev-row-top">
            <span class="sev-row-label">CVSS Score</span>
            <span class="sev-row-score">8.5 / 10</span>
          </div>
          <div class="sev-bar"><div class="sev-bar-fill"></div></div>
          <span class="sev-badge sev-c" style="width:fit-content">{{ vuln.severity|capitalize }}</span>
        </div>
      </div>

      <div class="d-card">
        <div class="d-card-label">Actions</div>
        <div class="action-stack">
          {% if vuln.url %}
            <a href="{{ vuln.url }}" target="_blank" class="act-btn act-primary">
              ↗ Voir l'advisory
            </a>
          {% endif %}
          <a href="{{ path('app_dashboard') }}" class="act-btn act-secondary">
            ← Retour au dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
