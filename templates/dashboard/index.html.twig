{% extends 'base.html.twig' %}
{% block title %}SecureScan — Dashboard{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}

{% block body %}
{% set vulns = job.vulnerabilities %}
{% set score = job.globalScore ?? 0 %}
{% set countError   = vulns|filter(v => v.severity == 'error')|length %}
{% set countWarning = vulns|filter(v => v.severity == 'warning')|length %}
{% set countInfo    = vulns|filter(v => v.severity == 'info')|length %}
{% set dashOffset   = 251 - (score / 100 * 251) %}

<div class="dashboard">

  <div class="dash-header">
    <div class="dash-left">
      <div class="dash-title">
        Rapport d'analyse
        <span class="dash-title-badge">✓ Terminé</span>
      </div>
      <div class="dash-repo">
        <span>◈</span>
        <a class="dash-repo-link" href="{{ job.repoUrl }}" target="_blank">
          {{ job.repoUrl|replace({'https://': '', 'http://': ''}) }}
        </a>
        {% if job.finishedAt %}
        <span>· {{ job.finishedAt|date('d/m/Y à H\\hi') }}</span>
        {% endif %}
      </div>
    </div>
    <div class="dash-actions">
      <div class="export-group">
        <a href="{{ path('app_dashboard_export_json', {id: job.id}) }}" class="exp-btn" title="Télécharger le rapport JSON">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M8 2v8m0 0-3-3m3 3 3-3M3 13h10" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          JSON
        </a>
        <a href="{{ path('app_dashboard_export_pdf', {id: job.id}) }}" class="exp-btn" title="Télécharger le rapport PDF">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="6" width="10" height="7" rx="1"/>
            <path d="M5 6V3h6v3M5 10h2m-2 2.5h4" stroke-linecap="round"/>
          </svg>
          PDF
        </a>
      </div>
      <a href="{{ path('app_home') }}" class="btn-rescan">↻ Nouveau scan</a>
    </div>
  </div>

  <div class="score-row">
    <div class="score-card">
      <div class="score-ring-wrap">
        <svg class="score-svg" viewBox="0 0 100 100">
          <defs>
            <linearGradient id="scoreGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#FF6B6B"/>
              <stop offset="100%" style="stop-color:#A78BFA"/>
            </linearGradient>
          </defs>
          <circle class="score-track" cx="50" cy="50" r="40"/>
          <circle class="score-fill" cx="50" cy="50" r="40"
                  style="stroke-dashoffset: {{ dashOffset }}"/>
        </svg>
        <div class="score-num">{{ score }}</div>
      </div>
      <div class="score-label">Score sécurité</div>
      <div class="score-verdict">
        {% if score >= 80 %}✅ Risque faible
        {% elseif score >= 50 %}⚠ Risque modéré
        {% else %}🔴 Risque élevé{% endif %}
      </div>
    </div>
    <div class="stats-strip">
      <div class="s-stat crit"><span class="s-num">{{ countError }}</span><span class="s-lbl">Critique</span></div>
      <div class="s-stat high"><span class="s-num">{{ countWarning }}</span><span class="s-lbl">Modéré</span></div>
      <div class="s-stat low"><span class="s-num">{{ countInfo }}</span><span class="s-lbl">Information</span></div>
      <div class="s-stat med"><span class="s-num">{{ vulns|length }}</span><span class="s-lbl">Total</span></div>
    </div>
  </div>

  {% set owaspVulns = vulns|filter(v => v.owaspCategory is not null) %}
  {% if owaspVulns|length > 0 %}
  <div class="owasp-row">
    {% set owaspGroups = {} %}
    {% for v in owaspVulns %}
      {% set cat = v.owaspCategory %}
      {% set owaspGroups = owaspGroups|merge({ (cat): (owaspGroups[cat] ?? 0) + 1 }) %}
    {% endfor %}
    {% for cat, count in owaspGroups|slice(0, 3) %}
    <div class="o-card a05">
      <div class="o-top"><span class="o-code">{{ cat }}</span><span class="o-count">{{ count }}</span></div>
      <div class="o-name">{{ cat }}</div>
      <div class="o-badges"><span class="sev-badge sev-c">{{ count }} occurrence{{ count > 1 ? 's' : '' }}</span></div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="vtable-card">
    <div class="vtable-top">
      <span class="vtable-title">Vulnérabilités détectées</span>
      <span class="vtable-count">{{ vulns|length }} résultat{{ vulns|length > 1 ? 's' : '' }}</span>
    </div>
    {% if vulns|length == 0 %}
    <div class="dashboard-empty">
      <div class="dashboard-empty-icon">🎉</div>
      <div class="dashboard-empty-title">Aucune vulnérabilité détectée</div>
      <div class="dashboard-empty-sub">Votre dépôt est propre selon les outils analysés.</div>
    </div>
    {% else %}
    <table>
      <thead>
        <tr>
          <th>Outil</th>
          <th>Fichier / Titre</th>
          <th>Sévérité</th>
          <th>OWASP</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for vuln in vulns %}
        <tr onclick="window.location='{{ path('app_vuln_detail', {id: vuln.id}) }}'">
          <td><span class="td-tool">{{ vuln.tool }}</span></td>
          <td>
            <div class="td-pkg">{{ vuln.title|length > 60 ? vuln.title|slice(0,60) ~ '…' : vuln.title }}</div>
            {% if vuln.filePath %}
            <div class="td-ver">{{ vuln.filePath }}{% if vuln.lineNumber %} · ligne {{ vuln.lineNumber }}{% endif %}</div>
            {% endif %}
          </td>
          <td>
            {% if vuln.severity == 'error' %}<span class="sev-badge sev-c">Critique</span>
            {% elseif vuln.severity == 'warning' %}<span class="sev-badge sev-h">Modéré</span>
            {% else %}<span class="sev-badge sev-l">Information</span>{% endif %}
          </td>
          <td>
            {% if vuln.owaspCategory %}
              <span class="owasp-pill op-a05">{{ vuln.owaspCategory }}</span>
            {% else %}
              <span class="owasp-empty">—</span>
            {% endif %}
          </td>
          <td class="td-arrow">›</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </div>

</div>
{% endblock %}
