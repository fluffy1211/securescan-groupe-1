<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}SecureScan{% endblock %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Cabinet+Grotesk:wght@400;500;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('css/base.css') }}">
{% block stylesheets %}{% endblock %}
</head>
<body>

<nav class="nav">
  <a class="nav-logo" href="{{ path('app_home') }}">
    <div class="nav-logo-mark">S</div>
    <span class="nav-logo-text">Secure<span>Scan</span></span>
  </a>

  {% if app.user and app.request.attributes.get('_route') not in ['app_login', 'app_register'] %}
  <div class="nav-center" id="nav-center-pill" style="display:none">
    <a class="nav-tab {% if app.request.attributes.get('_route') in ['app_dashboard', 'app_dashboard_empty'] %}active{% endif %}"
       id="nav-dashboard" href="{{ path('app_dashboard_empty') }}">Dashboard</a>
  </div>
  {% endif %}

  <div class="nav-right">
    {% if app.user %}
      {% if app.request.attributes.get('_route') not in ['app_login', 'app_register'] %}
      <a class="nav-history {% if app.request.attributes.get('_route') == 'app_history' %}active{% endif %}"
         href="{{ path('app_history') }}">Historique</a>
      {% endif %}
      <div class="nav-user" tabindex="0">
        <div class="nav-user-btn">
          <div class="nav-user-pic">{{ app.user.email|first|upper }}</div>
          <span class="nav-user-email">{{ app.user.email }}</span>
          <span class="nav-user-chevron">▼</span>
        </div>
        <div class="nav-dropdown">
          <a class="nav-dropdown-item" href="{{ path('app_profile') }}">
            <span>👤</span> Mon profil
          </a>
          <div class="nav-dropdown-sep"></div>
          <a class="nav-dropdown-item danger" href="{{ path('app_logout') }}">
            <span>↩</span> Déconnexion
          </a>
        </div>
      </div>
    {% else %}
      <a class="nav-btn-login" href="{{ path('app_register') }}">Inscription</a>
      <a class="nav-btn-login primary" href="{{ path('app_login') }}">Connexion</a>
    {% endif %}
  </div>
</nav>

{% block body %}{% endblock %}

{% block javascripts %}{% endblock %}

<script>
const dashTab = document.getElementById('nav-dashboard');
if (dashTab && localStorage.getItem('ss_last_scan')) {
  dashTab.style.display = 'flex';
  if (dashTab.dataset.active) dashTab.classList.add('active');
}
</script>
</body>
</html>
