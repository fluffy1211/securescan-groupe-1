{% extends 'base.html.twig' %}
{% block title %}SecureScan — Analysez la sécurité de votre code{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/home.css') }}">
{% endblock %}

{% block body %}
<section class="home">
  <div class="home-blob home-blob-1"></div>
  <div class="home-blob home-blob-2"></div>
  <div class="home-blob home-blob-3"></div>

  <div class="home-body">
    <h1 class="home-h1">
      Analysez la sécurité<br>de votre code <span class="hl">en secondes</span>
    </h1>

    <p class="home-sub">
      Collez l'URL de votre dépôt Git. SecureScan clone, analyse avec Semgrep,
      npm audit &amp; Composer, mappe sur l'OWASP et génère un rapport complet.
    </p>

    <form class="scan-form" action="{{ path('app_scan_launch') }}" method="POST">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token('scan_launch') }}">
      <div class="scan-prefix">
        <span class="scan-prefix-accent">❯</span>
        git clone
      </div>
      <input class="scan-input" type="text" name="repo"
        placeholder="https://github.com/organisation/projet.git" required />
      <button class="scan-submit" type="submit">
        Analyser →
      </button>
    </form>

    <div class="home-steps">
      <div class="step-card">
        <div class="step-icon">📥</div>
        <div class="step-title">Clone</div>
        <div class="step-desc">Clone le dépôt Git et prépare les fichiers pour l'analyse.</div>
      </div>
      <div class="step-card">
        <div class="step-icon">🔍</div>
        <div class="step-title">Analyse</div>
        <div class="step-desc">Semgrep · npm audit · Composer Audit détectent les failles.</div>
      </div>
      <div class="step-card">
        <div class="step-icon">📊</div>
        <div class="step-title">Rapport</div>
        <div class="step-desc">Score OWASP · Détails · Export des résultats.</div>
      </div>
    </div>

  </div>
</section>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/home.js') }}"></script>
{% endblock %}
