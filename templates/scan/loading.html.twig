{% extends 'base.html.twig' %}
{% block title %}SecureScan — Analyse en cours{% endblock %}

{% block stylesheets %}
<style>
.loading-wrap {
  min-height: calc(100vh - 60px);
  display: flex; align-items: center; justify-content: center;
  padding: 40px; position: relative; overflow: hidden;
}
.loading-blob {
  position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none;
}
.loading-blob-1 { width: 400px; height: 400px; background: rgba(255,107,107,0.1); top: -80px; right: -80px; }
.loading-blob-2 { width: 350px; height: 350px; background: rgba(167,139,250,0.1); bottom: -60px; left: -60px; }

.loading-body {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center;
  gap: 0; max-width: 520px; width: 100%; text-align: center;
}

.loading-status-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.2);
  border-radius: 100px; padding: 5px 14px 5px 8px;
  font-size: 0.78rem; font-weight: 600; color: var(--primary);
  margin-bottom: 20px;
}
.status-dot {
  width: 7px; height: 7px; background: var(--primary);
  border-radius: 50%; animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }

.loading-title {
  font-size: 2rem; font-weight: 900; letter-spacing: -0.5px;
  margin-bottom: 8px; color: var(--text);
}
.loading-repo {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-mono); font-size: 0.8rem; color: var(--text2);
  margin-bottom: 36px;
}

/* Steps */
.steps { display: flex; flex-direction: column; gap: 10px; width: 100%; margin-bottom: 24px; }

.step-card {
  background: var(--card); border: 1.5px solid var(--border);
  border-radius: var(--radius-xl); padding: 18px 22px;
  display: flex; align-items: center; gap: 16px;
  box-shadow: var(--shadow); text-align: left; transition: border-color 0.3s;
}
.step-card.active  { border-color: rgba(255,107,107,0.35); }
.step-card.done    { border-color: rgba(5,150,105,0.3); }

.step-icon-wrap {
  width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
  display: grid; place-items: center; font-size: 1rem;
  background: var(--surface); border: 1.5px solid var(--border);
  transition: all 0.3s;
}
.step-card.active .step-icon-wrap  { background: rgba(255,107,107,0.1); border-color: rgba(255,107,107,0.3); }
.step-card.done   .step-icon-wrap  { background: rgba(5,150,105,0.1);   border-color: rgba(5,150,105,0.3); }

.step-body { flex: 1; min-width: 0; }
.step-name { font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.step-state {
  font-size: 0.75rem; font-weight: 600; color: var(--text3);
  display: flex; align-items: center; gap: 5px;
}
.step-card.active .step-state { color: var(--primary); }
.step-card.done   .step-state { color: var(--green); }

.step-bar-wrap {
  height: 4px; background: var(--surface); border-radius: 2px;
  overflow: hidden; margin-top: 8px;
}
.step-bar-fill {
  height: 100%; border-radius: 2px; width: 0%;
  transition: width 0.4s ease;
}
.step-card.pending .step-bar-fill { background: var(--border2); }
.step-card.active  .step-bar-fill { background: var(--gradient); }
.step-card.done    .step-bar-fill { background: var(--green); width: 100% !important; }

/* Spinner */
.spin { animation: spin 1s linear infinite; display: inline-block; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.loading-hint { font-size: 0.78rem; color: var(--text3); }

/* Erreur */
.error-box {
  display: none; background: rgba(220,38,38,0.06);
  border: 1.5px solid rgba(220,38,38,0.2); border-radius: var(--radius-lg);
  padding: 16px 20px; margin-top: 16px; font-size: 0.85rem; color: var(--red);
  text-align: left; width: 100%;
}
.error-box strong { display: block; margin-bottom: 4px; font-weight: 700; }
</style>
{% endblock %}

{% block body %}
<div class="loading-wrap">
  <div class="loading-blob loading-blob-1"></div>
  <div class="loading-blob loading-blob-2"></div>

  <div class="loading-body">

    <div class="loading-status-badge">
      <span class="status-dot" id="status-dot"></span>
      <span id="status-label">{% if immediateError is defined and immediateError %}Échec de l'analyse{% else %}Analyse en cours...{% endif %}</span>
    </div>

    <div class="loading-title">Analyse de votre dépôt</div>
    <div class="loading-repo">
      <span>◈</span>
      <span>{% if immediateError is defined and immediateError %}{{ errorRepo|default('')|replace({'https://': '', 'http://': ''}) }}{% else %}{{ job.repoUrl|replace({'https://': '', 'http://': ''}) }}{% endif %}</span>
    </div>

    <div class="steps">

      <div class="step-card pending" id="step-1">
        <div class="step-icon-wrap" id="icon-1">📥</div>
        <div class="step-body">
          <div class="step-name">Clone du dépôt</div>
          <div class="step-state" id="state-1">En attente</div>
          <div class="step-bar-wrap"><div class="step-bar-fill" id="bar-1"></div></div>
        </div>
      </div>

      <div class="step-card pending" id="step-2">
        <div class="step-icon-wrap" id="icon-2">🔍</div>
        <div class="step-body">
          <div class="step-name">Analyse Semgrep · npm · Composer</div>
          <div class="step-state" id="state-2">En attente</div>
          <div class="step-bar-wrap"><div class="step-bar-fill" id="bar-2"></div></div>
        </div>
      </div>

      <div class="step-card pending" id="step-3">
        <div class="step-icon-wrap" id="icon-3">📊</div>
        <div class="step-body">
          <div class="step-name">Génération du rapport</div>
          <div class="step-state" id="state-3">En attente</div>
          <div class="step-bar-wrap"><div class="step-bar-fill" id="bar-3"></div></div>
        </div>
      </div>

    </div>

    <div class="loading-hint">Temps estimé : 30 – 60 secondes</div>

    <div class="error-box" id="error-box">
      <strong>Erreur lors de l'analyse</strong>
      <span id="error-msg">{% if immediateError is defined and immediateError %}{{ immediateError }}{% endif %}</span>
      <a href="{{ path('app_home') }}" style="display:inline-block;margin-top:10px;font-size:0.8rem;color:var(--primary);text-decoration:none;">← Réessayer</a>
    </div>

  </div>
</div>
{% endblock %}

{% block javascripts %}
{% if immediateError is defined and immediateError %}
<script>
(function() {
  document.getElementById('status-dot').style.background = '#DC2626';
  document.getElementById('error-box').style.display = 'block';
})();
</script>
{% else %}
<script>
const runUrl    = "{{ path('app_scan_run', {id: job.id}) }}";
const csrfToken = "{{ csrf_token('scan_run') }}";

function setStep(n, state) {
  const card  = document.getElementById('step-' + n);
  const icon  = document.getElementById('icon-' + n);
  const label = document.getElementById('state-' + n);
  const bar   = document.getElementById('bar-' + n);

  card.className = 'step-card ' + state;

  if (state === 'active') {
    label.innerHTML = '<span class="spin">↻</span> En cours...';
    bar.style.width = '65%';
    setTimeout(() => { if (card.className.includes('active')) bar.style.width = '85%'; }, 4000);
  } else if (state === 'done') {
    label.innerHTML = '✓ Terminé';
    bar.style.width = '100%';
    icon.textContent = '✅';
  }
}

// Timeline d'animation (indépendante du vrai avancement)
setTimeout(() => setStep(1, 'active'),  200);
setTimeout(() => setStep(1, 'done'),   5000);
setTimeout(() => setStep(2, 'active'), 5200);
setTimeout(() => setStep(2, 'done'),  25000);
setTimeout(() => setStep(3, 'active'), 25200);

// Lancement du scan réel en AJAX
fetch(runUrl, {
  method: 'POST',
  headers: { 'X-CSRF-Token': csrfToken },
})
.then(res => res.json())
.then(data => {
  if (data.status === 'done') {
    setStep(1, 'done');
    setStep(2, 'done');
    setStep(3, 'done');

    document.getElementById('status-dot').style.background = '#059669';
    document.getElementById('status-label').textContent = 'Analyse terminée !';

    setTimeout(() => { window.location.href = data.redirectUrl; }, 1000);
  } else {
    showError(data.error || 'Une erreur est survenue.');
  }
})
.catch(err => showError(err.message));

function showError(msg) {
  document.getElementById('status-dot').style.background = '#DC2626';
  document.getElementById('status-label').textContent = 'Échec de l\'analyse';
  document.getElementById('error-box').style.display = 'block';
  document.getElementById('error-msg').textContent = msg;
}
</script>
{% endif %}
{% endblock %}
