{% extends 'base.html.twig' %}
{% block title %}SecureScan — Historique{% endblock %}

{% block stylesheets %}
<style>
.history-wrap { padding: 36px 40px; max-width: 1000px; margin: 0 auto; }
.page-header { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
.page-title { font-size: 1.8rem; font-weight: 900; letter-spacing: -0.5px; margin-bottom: 4px; }
.page-sub { font-size: 0.88rem; color: var(--text2); }

.history-grid { display: flex; flex-direction: column; gap: 10px; }

.scan-card {
  background: var(--card); border: 1.5px solid var(--border);
  border-radius: var(--radius-xl); padding: 20px 24px;
  display: grid; grid-template-columns: 1fr auto;
  align-items: center; gap: 20px;
  cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s;
  text-decoration: none; color: inherit;
  box-shadow: var(--shadow);
}
.scan-card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); }

.scan-left { display: flex; flex-direction: column; gap: 10px; }
.scan-repo {
  display: flex; align-items: center; gap: 8px;
  font-size: 0.9rem; font-weight: 700; color: var(--text);
}
.scan-repo-icon {
  width: 28px; height: 28px; background: var(--surface);
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  display: grid; place-items: center; color: var(--text2); font-size: 0.8rem; flex-shrink: 0;
}
.scan-meta {
  display: flex; align-items: center; gap: 14px;
  font-size: 0.78rem; color: var(--text3);
}
.scan-badges { display: flex; align-items: center; gap: 5px; }

.scan-right { display: flex; align-items: center; gap: 12px; }
.scan-score {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  padding: 10px 16px; border-radius: var(--radius-lg);
  border: 1.5px solid var(--border); background: var(--bg2);
  min-width: 62px; box-shadow: var(--shadow);
}
.scan-score-num { font-size: 1.4rem; font-weight: 900; letter-spacing: -1px; line-height: 1; }
.scan-score-lbl { font-size: 0.6rem; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
.score-good { color: var(--green); }
.score-med  { color: var(--amber); }
.score-bad  { color: var(--red); }

.scan-arrow { color: var(--text3); font-size: 1.2rem; }
.scan-card:hover .scan-arrow { color: var(--primary); }

.empty-state { text-align: center; padding: 80px 20px; }
.empty-icon { font-size: 2.8rem; margin-bottom: 16px; opacity: 0.25; }
.empty-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
.empty-sub { font-size: 0.82rem; color: var(--text3); }
.empty-btn {
  display: inline-block; margin-top: 20px;
  padding: 10px 22px; border-radius: 100px;
  background: var(--gradient); color: #fff;
  font-weight: 700; font-size: 0.85rem; text-decoration: none;
  transition: opacity 0.15s;
}
.empty-btn:hover { opacity: 0.88; }

@media (max-width: 768px) {
  .history-wrap { padding: 24px 20px; }
  .scan-card { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block body %}
<div class="history-wrap">

  <div class="page-header">
    <div class="page-title">Historique des scans</div>
    <div class="page-sub">
      {{ app.user.email }} · {{ scanJobs|length }} scan{{ scanJobs|length != 1 ? 's' : '' }} effectué{{ scanJobs|length != 1 ? 's' : '' }}
    </div>
  </div>

  <div class="history-grid">
    {% if scanJobs is empty %}
      <div class="empty-state">
        <div class="empty-icon">🔍</div>
        <div class="empty-title">Aucun scan effectué pour le moment</div>
        <div class="empty-sub">Lancez votre premier scan depuis le tableau de bord</div>
      </div>
    {% else %}
      {% for job in scanJobs %}
        {% set score = job.globalScore %}
        {% set scoreClass = score >= 75 ? 'score-good' : (score >= 50 ? 'score-med' : 'score-bad') %}
        {% set errorCount   = 0 %}
        {% set warningCount = 0 %}
        {% set infoCount    = 0 %}
        {% for vuln in job.vulnerabilities %}
          {% if vuln.severity == 'error' %}
            {% set errorCount = errorCount + 1 %}
          {% elseif vuln.severity == 'warning' %}
            {% set warningCount = warningCount + 1 %}
          {% else %}
            {% set infoCount = infoCount + 1 %}
          {% endif %}
        {% endfor %}
        <a class="scan-card" href="{{ path('app_vuln_detail', {id: job.id}) }}">
          <div class="scan-left">
            <div class="scan-repo">
              <span class="scan-repo-icon">◈</span>
              {{ job.repoUrl }}
            </div>
            <div class="scan-meta">
              <span class="scan-date">📅 {{ job.createdAt|date('d M Y · H\hi') }}</span>
              <div class="scan-badges">
                {% if errorCount > 0 %}
                  <span class="sev-badge sev-c">{{ errorCount }} Error</span>
                {% endif %}
                {% if warningCount > 0 %}
                  <span class="sev-badge sev-h">{{ warningCount }} Warning</span>
                {% endif %}
                {% if infoCount > 0 %}
                  <span class="sev-badge sev-l">{{ infoCount }} Info</span>
                {% endif %}
                {% if job.status != 'done' %}
                  <span class="sev-badge">{{ job.status }}</span>
                {% endif %}
              </div>
            </div>
          </div>
          <div class="scan-right">
            <div class="scan-score">
              <span class="scan-score-num {{ scoreClass }}">{{ score ?? '—' }}</span>
              <span class="scan-score-lbl">Score</span>
            </div>
            <span class="scan-arrow">›</span>
          </div>
        </a>
      {% endfor %}
    {% endif %}
  </div>

</div>
{% endblock %}
