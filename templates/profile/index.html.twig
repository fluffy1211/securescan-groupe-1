{% extends 'base.html.twig' %}
{% block title %}SecureScan — Profil{% endblock %}

{% block stylesheets %}
<style>
.profile-wrap { padding: 36px 40px; max-width: 800px; margin: 0 auto; }
.page-header { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
.page-title { font-size: 1.2rem; font-weight: 800; letter-spacing: -0.4px; }

.profile-grid { display: flex; flex-direction: column; gap: 16px; }
.p-card { background: var(--card); border: 1px solid var(--border2); border-radius: var(--radius-xl); padding: 28px; }
.p-card-label {
  font-family: var(--font-mono); font-size: 0.6rem; color: var(--text3);
  letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px;
  display: flex; align-items: center; gap: 8px;
}
.p-card-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.avatar-row { display: flex; align-items: center; gap: 20px; margin-bottom: 8px; }
.avatar-big {
  width: 64px; height: 64px; border-radius: 50%;
  background: var(--cyan-dim); border: 2px solid rgba(0,217,245,0.3);
  display: grid; place-items: center;
  font-family: var(--font-mono); font-size: 1.6rem; font-weight: 700; color: var(--cyan);
  flex-shrink: 0;
}
.avatar-info { display: flex; flex-direction: column; gap: 6px; }
.avatar-email { font-size: 1rem; font-weight: 700; }
.avatar-roles { display: flex; flex-wrap: wrap; gap: 6px; }
.avatar-role {
  font-family: var(--font-mono); font-size: 0.62rem;
  padding: 2px 8px; border-radius: 4px;
  background: var(--green-dim); border: 1px solid rgba(54,245,160,0.25);
  color: var(--green); width: fit-content;
}

.p-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.p-field:last-child { margin-bottom: 0; }
.p-label { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text3); letter-spacing: 1px; text-transform: uppercase; }
.p-value {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 11px 14px;
  font-family: var(--font-mono); font-size: 0.78rem; color: var(--text2);
}
.p-input {
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: var(--radius); padding: 11px 14px;
  font-family: var(--font-mono); font-size: 0.78rem; color: var(--text);
  outline: none; transition: border-color 0.15s; width: 100%;
}
.p-input:focus { border-color: var(--cyan); }

.p-btn {
  padding: 10px 20px; border-radius: var(--radius);
  border: none; background: var(--cyan); color: var(--bg);
  font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
  cursor: pointer; transition: background 0.15s; letter-spacing: 0.3px;
}
.p-btn:hover { background: #33E4FF; }

.alert {
  border-radius: var(--radius); padding: 10px 14px; margin-bottom: 16px;
  font-family: var(--font-mono); font-size: 0.68rem;
}
.alert-error   { background: var(--red-dim);   border: 1px solid rgba(245,54,92,0.3);  color: var(--red); }
.alert-success { background: var(--green-dim); border: 1px solid rgba(54,245,160,0.3); color: var(--green); }

.danger-btn {
  background: transparent; border: 1px solid rgba(245,54,92,0.3);
  color: var(--red); padding: 10px 20px; border-radius: var(--radius);
  font-family: var(--font-mono); font-size: 0.68rem; cursor: pointer;
  transition: all 0.15s; letter-spacing: 0.5px;
}
.danger-btn:hover { background: var(--red-dim); border-color: var(--red); }

/* Modal confirmation */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.7); z-index: 999;
  align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-box {
  background: var(--card); border: 1px solid var(--border2);
  border-radius: var(--radius-xl); padding: 32px; max-width: 420px; width: 90%;
}
.modal-title { font-size: 1rem; font-weight: 800; margin-bottom: 8px; }
.modal-desc { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text2); margin-bottom: 24px; line-height: 1.6; }
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; }
.modal-cancel {
  padding: 9px 18px; border-radius: var(--radius);
  border: 1px solid var(--border2); background: transparent;
  color: var(--text2); font-family: var(--font-mono); font-size: 0.7rem;
  cursor: pointer; transition: all 0.15s;
}
.modal-cancel:hover { border-color: var(--text2); color: var(--text); }

@media (max-width: 768px) {
  .profile-wrap { padding: 24px 20px; }
}
</style>
{% endblock %}

{% block body %}
<div class="profile-wrap">
  <div class="page-header">
    <div class="page-title">Mon profil</div>
  </div>

  <div class="profile-grid">

    {# Informations du compte #}
    <div class="p-card">
      <div class="p-card-label">Informations du compte</div>
      <div class="avatar-row">
        <div class="avatar-big">{{ app.user.email|first|upper }}</div>
        <div class="avatar-info">
          <div class="avatar-email">{{ app.user.email }}</div>
          <div class="avatar-roles">
            {% for role in app.user.roles %}
              {% if role != 'ROLE_USER' %}
                <span class="avatar-role">{{ role }}</span>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="p-field">
        <div class="p-label">Adresse email</div>
        <div class="p-value">{{ app.user.email }}</div>
      </div>
    </div>

    {# Changer le mot de passe #}
    <div class="p-card">
      <div class="p-card-label">Changer le mot de passe</div>

      {% for msg in app.flashes('password_error') %}
        <div class="alert alert-error">{{ msg }}</div>
      {% endfor %}
      {% for msg in app.flashes('password_success') %}
        <div class="alert alert-success">{{ msg }}</div>
      {% endfor %}

      <form method="post" action="{{ path('app_profile_password') }}">
        <div class="p-field">
          <label class="p-label" for="current_password">Mot de passe actuel</label>
          <input class="p-input" type="password" id="current_password" name="current_password" autocomplete="current-password" required>
        </div>
        <div class="p-field">
          <label class="p-label" for="new_password">Nouveau mot de passe</label>
          <input class="p-input" type="password" id="new_password" name="new_password" autocomplete="new-password" minlength="8" required>
        </div>
        <div class="p-field">
          <label class="p-label" for="confirm_password">Confirmer le nouveau mot de passe</label>
          <input class="p-input" type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" minlength="8" required>
        </div>
        <button class="p-btn" type="submit">Mettre à jour le mot de passe</button>
      </form>
    </div>

    {# Zone danger #}
    <div class="p-card">
      <div class="p-card-label">Zone danger</div>
      <p style="font-family:var(--font-mono);font-size:0.7rem;color:var(--text2);margin-bottom:16px;line-height:1.6;">
        La suppression de votre compte est irréversible. Toutes vos données seront définitivement effacées.
      </p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <a class="danger-btn" href="{{ path('app_logout') }}" style="text-decoration:none;display:inline-block;">Se déconnecter</a>
        <button class="danger-btn" type="button" onclick="document.getElementById('modal-delete').classList.add('open')">
          Supprimer mon compte
        </button>
      </div>
    </div>

  </div>
</div>

{# Modal confirmation suppression #}
<div class="modal-overlay" id="modal-delete">
  <div class="modal-box">
    <div class="modal-title">Supprimer le compte ?</div>
    <div class="modal-desc">
      Cette action est <strong style="color:var(--red)">irréversible</strong>.<br>
      Votre compte et toutes vos données associées seront définitivement supprimés.
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" type="button" onclick="document.getElementById('modal-delete').classList.remove('open')">
        Annuler
      </button>
      <form method="post" action="{{ path('app_profile_delete') }}" style="margin:0;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
        <button class="danger-btn" type="submit">Oui, supprimer</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}
