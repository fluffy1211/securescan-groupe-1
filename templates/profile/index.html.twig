{% extends 'base.html.twig' %}

{% block title %}SecureScan — Profil{% endblock %}

{% block stylesheets %}
<style>
.profile-wrap { padding: 36px 40px; max-width: 800px; margin: 0 auto; }
.page-header { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
.page-title { font-size: 1.2rem; font-weight: 800; letter-spacing: -0.4px; }

.profile-grid { display: flex; flex-direction: column; gap: 16px; }

.p-card { background: var(--card); border: 1px solid var(--border2); border-radius: var(--radius-xl); padding: 28px; }
.p-card-label {
  font-family: var(--font-mono); font-size: 0.6rem; color: var(--text3);
  letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px;
  display: flex; align-items: center; gap: 8px;
}
.p-card-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

/* Avatar row */
.avatar-row { display: flex; align-items: center; gap: 20px; margin-bottom: 24px; }
.avatar-big {
  width: 64px; height: 64px; border-radius: 50%;
  background: var(--cyan-dim); border: 2px solid rgba(0,217,245,0.3);
  display: grid; place-items: center;
  font-family: var(--font-mono); font-size: 1.6rem; font-weight: 700; color: var(--cyan);
}
.avatar-info { display: flex; flex-direction: column; gap: 4px; }
.avatar-email { font-size: 1rem; font-weight: 700; }
.avatar-role {
  font-family: var(--font-mono); font-size: 0.62rem;
  padding: 2px 8px; border-radius: 4px;
  background: var(--green-dim); border: 1px solid rgba(54,245,160,0.25);
  color: var(--green); width: fit-content;
}

/* Fields */
.p-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.p-label { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text3); letter-spacing: 1px; text-transform: uppercase; }
.p-value {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 11px 14px;
  font-family: var(--font-mono); font-size: 0.78rem; color: var(--text2);
}

/* Stats */
.stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
.stat-box {
  background: var(--surface); border: 1px solid var(--border2);
  border-radius: var(--radius-lg); padding: 16px;
  display: flex; flex-direction: column; gap: 4px; text-align: center;
}
.stat-num { font-size: 1.6rem; font-weight: 900; letter-spacing: -1px; color: var(--cyan); }
.stat-lbl { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; }

/* Danger zone */
.danger-btn {
  background: transparent; border: 1px solid rgba(245,54,92,0.3);
  color: var(--red); padding: 10px 20px; border-radius: var(--radius);
  font-family: var(--font-mono); font-size: 0.68rem; cursor: pointer;
  transition: all 0.15s; letter-spacing: 0.5px;
}
.danger-btn:hover { background: var(--red-dim); border-color: var(--red); }

.empty-state {
  text-align: center; padding: 80px 20px;
  font-family: var(--font-mono); color: var(--text3);
}
.empty-icon { font-size: 2.5rem; margin-bottom: 16px; opacity: 0.3; }

@media (max-width: 768px) {
  .profile-wrap { padding: 24px 20px; }
  .stats-row { grid-template-columns: 1fr 1fr; }
}
</style>
{% endblock %}

{% block body %}
<div class="profile-wrap">
  <div class="page-header">
    <div class="page-title">Mon profil</div>
  </div>

  <div id="profile-content">
    <div class="empty-state">
      <div class="empty-icon">🔒</div>
      <div>Connectez-vous pour accéder à votre profil</div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
  const user = JSON.parse(localStorage.getItem('ss_user') || 'null');
  if (!user) return;

  const letter = user.email[0].toUpperCase();

  document.getElementById('profile-content').innerHTML = `
    <div class="profile-grid">

      <div class="p-card">
        <div class="p-card-label">Informations du compte</div>
        <div class="avatar-row">
          <div class="avatar-big">${letter}</div>
          <div class="avatar-info">
            <div class="avatar-email">${user.email}</div>
            <span class="avatar-role">ROLE_USER</span>
          </div>
        </div>
        <div class="p-field">
          <div class="p-label">Adresse email</div>
          <div class="p-value">${user.email}</div>
        </div>
        <div class="p-field">
          <div class="p-label">Membre depuis</div>
          <div class="p-value">Mars 2026</div>
        </div>
      </div>

      <div class="p-card">
        <div class="p-card-label">Statistiques</div>
        <div class="stats-row">
          <div class="stat-box">
            <span class="stat-num">3</span>
            <span class="stat-lbl">Scans effectués</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">14</span>
            <span class="stat-lbl">Vulnérabilités trouvées</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">60</span>
            <span class="stat-lbl">Score moyen</span>
          </div>
        </div>
      </div>

      <div class="p-card">
        <div class="p-card-label">Zone danger</div>
        <button class="danger-btn" onclick="
          localStorage.removeItem('ss_user');
          location.href='/';
        ">Se déconnecter</button>
      </div>

    </div>
  `;
})();
</script>
{% endblock %}
